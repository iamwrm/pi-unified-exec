{
	"name": "pi-unified-exec",
	"version": "0.8.0",
	"description": "Codex-style unified_exec for pi: long-lived shell sessions the LLM polls and drives with write_stdin (Ctrl-C, arrow keys, PTY, REPLs, ssh, dev servers). Full output logged to disk.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"codex",
		"unified-exec",
		"bash",
		"pty"
	],
	"license": "MIT",
	"author": "Ren Wang <iamwrm@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/iamwrm/pi-unified-exec.git"
	},
	"bugs": {
		"url": "https://github.com/iamwrm/pi-unified-exec/issues"
	},
	"homepage": "https://github.com/iamwrm/pi-unified-exec#readme",
	"type": "module",
	"engines": {
		"node": ">=22.19.0"
	},
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.80.5",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"optionalDependencies": {
		"@homebridge/node-pty-prebuilt-multiarch": "0.13.1"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.80.10",
		"@earendil-works/pi-tui": "0.80.10",
		"@types/node": "^22.0.0",
		"tsx": "^4.19.0",
		"typebox": "1.1.24",
		"typescript": "^5.6.0"
	}
}
